flowchart TD
    subgraph Consumer["Consumer Application"]
        PP["ProxyPayProvider"]
        PIX["PixPayment Component"]
        INV["InvoicePayment Component"]
        BIL["BillingPayment Component"]
        HOOK["useProxyPay Hook"]
    end

    subgraph Library["proxypay-react Library"]
        SVC["ProxyPayService"]
        CTX["ProxyPayContext"]
        TYPES["TypeScript Interfaces"]
    end

    subgraph Backend["ProxyPay API"]
        REST["REST Endpoints"]
        GQL["GraphQL Endpoint"]
        WH["Webhook Handler"]
    end

    subgraph External["External Services"]
        AP["AbacatePay Gateway"]
        BANK["Banking / PIX Network"]
    end

    PP -->|configures| CTX
    CTX -->|instantiates| SVC
    PIX -->|createQRCode + polling| CTX
    INV -->|createInvoice + redirect| CTX
    BIL -->|createBilling + redirect| CTX
    HOOK -->|direct API access| CTX

    SVC -->|HTTP + X-Tenant-Id| REST
    REST -->|creates payments| AP
    AP -->|processes| BANK
    AP -->|billing.paid event| WH
    WH -->|updates invoice status| REST

    GQL -.->|read queries| REST

    style Consumer fill:#ecfdf5,stroke:#0d9488,color:#1e293b
    style Library fill:#eff6ff,stroke:#3b82f6,color:#1e293b
    style Backend fill:#fefce8,stroke:#ca8a04,color:#1e293b
    style External fill:#fef2f2,stroke:#ef4444,color:#1e293b
